<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="800" prefWidth="1280" style="-fx-background-color: #111111;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CustomerDashboardController">

    <!-- SIDEBAR -->
    <VBox prefHeight="800" prefWidth="200" styleClass="dashboard-sidebar">

        <HBox prefHeight="64" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 20;">
    <Label styleClass="dashboard-sidebar-logo" text="FOR" />
    <Label styleClass="dashboard-sidebar-logo" text="BIG" style="-fx-text-fill: #8B5E3C;" />
    <Label styleClass="dashboard-sidebar-logo" text="BACKS" />
</HBox>

        <Region maxWidth="200" prefHeight="1" style="-fx-background-color: #2a2a2a;">
            <VBox.margin><Insets bottom="8" /></VBox.margin>
        </Region>

        <Button maxWidth="200" onAction="#goHome" styleClass="dashboard-nav-button-active" text="  Home" />
        <Button maxWidth="200" onAction="#goBrowse" styleClass="dashboard-nav-button" text="  Browse" />
        <Button maxWidth="200" onAction="#goCart" styleClass="dashboard-nav-button" text="  Cart" />
        <Button maxWidth="200" onAction="#goOrders" styleClass="dashboard-nav-button" text="  Orders" />

    </VBox>

    <!-- MAIN -->
    <VBox prefHeight="800" prefWidth="1080" style="-fx-background-color: #111111;">

        <!-- TOP BAR -->
        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="dashboard-topbar">
             <Label fx:id="loyaltyPointsBadge" styleClass="dashboard-points-badge" text="0 pts" />
             <Button onAction="#handleLogout" styleClass="dashboard-logout-button" text="Logout" />
        </HBox>

        <!-- CONTENT -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: #111111; -fx-background: #111111;" VBox.vgrow="ALWAYS">

            <VBox spacing="20" styleClass="dashboard-content-area">

                <!-- STATS -->
                <Label styleClass="dashboard-section-title" text="OVERVIEW" />

                <HBox fillHeight="true" spacing="14">
                    <VBox spacing="8" styleClass="dashboard-stat-card">
                        <Label styleClass="dashboard-stat-label" text="Total Orders" />
                        <Label fx:id="totalOrdersLabel" styleClass="dashboard-stat-value" text="0" />
                    </VBox>
                    <VBox spacing="8" styleClass="dashboard-stat-card">
                        <Label styleClass="dashboard-stat-label" text="Loyalty Points" />
                        <Label fx:id="pointsStatLabel" styleClass="dashboard-stat-value-brown" text="0" />
                    </VBox>
                    <VBox spacing="8" styleClass="dashboard-stat-card">
                        <Label styleClass="dashboard-stat-label" text="Favourite Category" />
                        <Label fx:id="favouriteCategoryLabel" style="-fx-font-size: 18px;" styleClass="dashboard-stat-value" text="-" />
                    </VBox>
                </HBox>

                <!-- RESTAURANTS -->
                <Label styleClass="dashboard-section-title" text="RESTAURANTS">
                    <VBox.margin><Insets top="8" /></VBox.margin>
                </Label>
                <FlowPane fx:id="restaurantsContainer" hgap="14" vgap="14" />

                <!-- SUGGESTIONS -->
                <Label styleClass="dashboard-section-title" text="SUGGESTED FOR YOU">
                    <VBox.margin><Insets top="8" /></VBox.margin>
                </Label>
                <FlowPane fx:id="suggestionsContainer" hgap="14" vgap="14" />

            </VBox>
        </ScrollPane>

    </VBox>

</HBox>
