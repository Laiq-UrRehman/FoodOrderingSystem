<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="800" prefWidth="1280" style="-fx-background-color: #111111;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="OrderTrackingController">

    <!-- SIDEBAR -->
    <VBox prefHeight="800" prefWidth="200" styleClass="dashboard-sidebar">

        <Label styleClass="dashboard-sidebar-logo" text="FORBIGBACKS">
            <VBox.margin><Insets bottom="16" left="20" top="20" /></VBox.margin>
        </Label>

        <Region maxWidth="200" prefHeight="1" style="-fx-background-color: #2a2a2a;">
            <VBox.margin><Insets bottom="8" /></VBox.margin>
        </Region>

        <Button maxWidth="200" onAction="#goHome" styleClass="dashboard-nav-button" text="  Home" />
        <Button maxWidth="200" onAction="#goBrowse" styleClass="dashboard-nav-button" text="  Browse" />
        <Button maxWidth="200" onAction="#goCart" styleClass="dashboard-nav-button" text="  Cart" />
        <Button maxWidth="200" onAction="#goOrders" styleClass="dashboard-nav-button" text="  Orders" />
        <Button maxWidth="200" onAction="#goTracking" styleClass="dashboard-nav-button-active" text="  Tracking" />

    </VBox>

    <!-- MAIN -->
    <VBox prefHeight="800" prefWidth="1080" style="-fx-background-color: #111111;">

        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="dashboard-topbar">
            <Button onAction="#goBack" styleClass="dashboard-back-button" text="← Back" />
            <Label styleClass="dashboard-topbar-name" text="Order Tracking" HBox.hgrow="ALWAYS" />
            <Button onAction="#refresh" styleClass="dashboard-logout-button" text="↻  Refresh" />
        </HBox>

        <!-- CONTENT built programmatically in controller -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: #111111; -fx-background: #111111;" VBox.vgrow="ALWAYS">
            <VBox fx:id="trackingContent" spacing="20" styleClass="dashboard-content-area" />
        </ScrollPane>

    </VBox>

</HBox>
